# ── DISHA Global — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# MongoDB connection for mammo-global database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/mammo_global_db

# Cross-DB: mammo-client's MongoDB (for doctor credential verification)
MAMMO_CLIENT_URI=mongodb+srv://<user>:<password>@<cluster>/mammo_db

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=<replace-with-64-char-hex>

# Local mammo-server URL (FastAPI training node)
MAMMO_SERVER_URL=http://localhost:8000

# API key shared with mammo-server for endpoint authentication
# Must match NODE_API_KEY in mammo-server/.env
MAMMO_NODE_API_KEY=<replace-with-random-key>

# Next.js public URL (used for redirects)
NEXTAUTH_URL=http://localhost:3001
